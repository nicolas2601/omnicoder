{
  "$schema": "https://omnicoder.dev/settings-schema.json",
  "$version": 3,
  "security": {
    "auth": {
      "selectedType": "openai"
    }
  },
  "model": {
    "name": "coder-model"
  },
  "tools": {
    "approvalMode": "auto-edit"
  },
  "context": {
    "fileFiltering": {
      "enableFuzzySearch": true
    }
  },
  "model.generationConfig": {
    "enableCacheControl": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/security-guard.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/pre-edit-guard.sh" }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/subagent-inject.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/post-tool-dispatcher.sh" }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/subagent-error-recover.sh" },
          { "type": "command", "command": "bash ~/.omnicoder/hooks/subagent-verify.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/skill-router-lite.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/session-init.sh" },
          { "type": "command", "command": "bash ~/.omnicoder/hooks/memory-loader.sh" },
          { "type": "command", "command": "bash ~/.omnicoder/hooks/token-budget.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/auto-handoff.sh" },
          { "type": "command", "command": "bash ~/.omnicoder/hooks/reflection.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "bash ~/.omnicoder/hooks/notify-desktop.sh" }
        ]
      }
    ]
  }
}
