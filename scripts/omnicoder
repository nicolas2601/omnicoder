#!/usr/bin/env bash
# ============================================================
# OmniCoder - CLI Wrapper
# Lanza qwen CLI con branding OmniCoder y carga .env auto
# ============================================================

OMNI_DIR="$HOME/.omnicoder"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" 2>/dev/null && pwd || echo "$OMNI_DIR")"

# Auto-patch branding si qwen se actualizo (silencioso)
if [[ -f "$SCRIPT_DIR/patch-branding.sh" ]]; then
    bash "$SCRIPT_DIR/patch-branding.sh" --quiet 2>/dev/null || true
elif [[ -f "$OMNI_DIR/../omnicoder/scripts/patch-branding.sh" ]]; then
    bash "$OMNI_DIR/../omnicoder/scripts/patch-branding.sh" --quiet 2>/dev/null || true
fi

CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
NC='\033[0m'

# Cargar .env si existe (provider activo)
if [[ -f "$OMNI_DIR/.env" ]]; then
    set -a
    source "$OMNI_DIR/.env"
    set +a
fi

# Info pre-launch (solo en modo interactivo, no headless)
if [[ $# -eq 0 ]] || [[ "$1" != "-p" ]]; then
    echo ""
    echo -e "  ${DIM}168 agentes | 193 skills | 18 hooks | 21 commands${NC}"
    echo ""
fi

# Pasar todo a qwen
exec qwen "$@"
