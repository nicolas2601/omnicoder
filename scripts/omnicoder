#!/usr/bin/env bash
# ============================================================
# OmniCoder - CLI Wrapper
# Lanza qwen CLI con branding OmniCoder y carga .env auto
# ============================================================

OMNI_DIR="$HOME/.omnicoder"
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
NC='\033[0m'

# Cargar .env si existe (provider activo)
if [[ -f "$OMNI_DIR/.env" ]]; then
    set -a
    source "$OMNI_DIR/.env"
    set +a
fi

# Banner OmniCoder (solo en modo interactivo, no headless)
if [[ $# -eq 0 ]] || [[ "$1" != "-p" ]]; then
    echo -e "${CYAN}${BOLD}"
    cat << 'BANNER'

   ____                  _ ______          __
  / __ \____ ___  ____  (_) ____/___  ____/ /__  _____
 / / / / __ `__ \/ __ \/ / /   / __ \/ __  / _ \/ ___/
/ /_/ / / / / / / / / / / /___/ /_/ / /_/ /  __/ /
\____/_/ /_/ /_/_/ /_/_/\____/\____/\__,_/\___/_/

BANNER
    echo -e "${NC}"

    # Mostrar info del provider activo
    if [[ -n "${OPENAI_MODEL:-}" ]]; then
        echo -e "  ${DIM}Model:${NC} ${GREEN}${OPENAI_MODEL}${NC}"
    fi
    if [[ -n "${OPENAI_BASE_URL:-}" ]]; then
        PROVIDER_NAME="custom"
        case "${OPENAI_BASE_URL}" in
            *nvidia*) PROVIDER_NAME="NVIDIA NIM" ;;
            *generativelanguage*) PROVIDER_NAME="Google Gemini" ;;
            *minimax*) PROVIDER_NAME="MiniMax" ;;
            *deepseek*) PROVIDER_NAME="DeepSeek" ;;
            *openrouter*) PROVIDER_NAME="OpenRouter" ;;
            *localhost*|*127.0.0.1*) PROVIDER_NAME="Ollama (local)" ;;
        esac
        echo -e "  ${DIM}Provider:${NC} ${GREEN}${PROVIDER_NAME}${NC}"
    fi
    echo -e "  ${DIM}168 agentes | 193 skills | 18 hooks | 21 commands${NC}"
    echo ""
fi

# Pasar todo a qwen
exec qwen "$@"
