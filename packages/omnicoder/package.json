{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@omnicoder/core",
  "version": "5.0.0-alpha.2",
  "description": "OmniCoder core plugin: skill routing, security guard, token budget, memory layer on top of Opencode",
  "type": "module",
  "license": "MIT",
  "author": "nicolas2601 <nm5571762@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicolas2601/omnicoder-v5"
  },
  "keywords": [
    "opencode-plugin",
    "ai",
    "coding-agent",
    "skills",
    "memory",
    "router"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./memory": "./src/memory/index.ts",
    "./router": "./src/router/index.ts",
    "./security": "./src/security/index.ts",
    "./budget": "./src/budget/index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test --timeout 30000",
    "test:ci": "mkdir -p .artifacts/unit && bun test --timeout 30000 --reporter=junit --reporter-outfile=.artifacts/unit/junit.xml",
    "build": "echo 'no build — consumed as source by opencode workspace'"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opencode-ai/sdk": "*"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "5.9.3"
  }
}
