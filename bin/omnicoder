#!/bin/sh
# shellcheck shell=sh
# -----------------------------------------------------------------------------
# omnicoder — user-facing CLI wrapper around the `opencode` binary.
#
# ADR-001: the upstream fork is kept mergeable; we never rename the underlying
# command. This shim exposes the product name `omnicoder`, injects environment
# and config indirection, and keeps the experience coherent across *nix shells.
#
# POSIX-compliant (sh, bash 3.2+, dash, zsh). No bashisms.
# -----------------------------------------------------------------------------

set -eu

# ---- constants --------------------------------------------------------------
OMNICODER_HOME_DEFAULT="${HOME}/.omnicoder"
OMNICODER_HOME="${OMNICODER_HOME:-$OMNICODER_HOME_DEFAULT}"
export OMNICODER_HOME

OMNICODER_BANNER_FLAG="${OMNICODER_HOME}/.banner-shown"
OMNICODER_USER_CONFIG="${OMNICODER_HOME}/opencode.jsonc"

# Auto-load API keys stashed by scripts/setup.sh. This lets users launch
# `omnicoder` from any shell (fish, dash, restricted bash) without having
# to re-export NVIDIA_API_KEY etc. every session. Accept both `env` and
# `.env` so legacy v4 installs keep working without manual rename.
for envfile in "${OMNICODER_HOME}/env" "${OMNICODER_HOME}/.env"; do
  if [ -f "$envfile" ]; then
    set -a
    # shellcheck disable=SC1090
    . "$envfile"
    set +a
    break
  fi
done

# ---- version lookup ---------------------------------------------------------
# Read version from the installed package.json. Walk upward from this script so
# we work both from the repo checkout and from a bin-only install.
omnicoder_script_dir() {
  # Resolve symlinks without relying on GNU readlink -f (macOS compatibility).
  src=$0
  while [ -L "$src" ]; do
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case $src in
      /*) ;;
      *) src="$dir/$src" ;;
    esac
  done
  cd -P "$(dirname "$src")" && pwd
}

find_package_json() {
  d=$(omnicoder_script_dir)
  # Try common locations in order:
  #   1. sibling packages/omnicoder/package.json (repo checkout)
  #   2. ../share/omnicoder/package.json (system install)
  #   3. $OMNICODER_HOME/package.json (user install)
  for candidate in \
    "$d/../packages/omnicoder/package.json" \
    "$d/../share/omnicoder/package.json" \
    "$OMNICODER_HOME/package.json"
  do
    if [ -f "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
  return 1
}

read_pkg_version() {
  pkg=$1
  # POSIX grep + sed only. Tolerant of whitespace/quotes variants.
  grep -E '"version"[[:space:]]*:' "$pkg" \
    | head -n 1 \
    | sed -E 's/.*"version"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/'
}

OMNICODER_VERSION="unknown"
if pkg_path=$(find_package_json); then
  v=$(read_pkg_version "$pkg_path" 2>/dev/null || true)
  if [ -n "${v:-}" ]; then
    OMNICODER_VERSION=$v
  fi
fi
export OMNICODER_VERSION

# ---- provider detection -----------------------------------------------------
detect_providers() {
  providers=""
  if [ -n "${NVIDIA_API_KEY:-}" ]; then providers="${providers}nvidia-nim "; fi
  if [ -n "${MINIMAX_API_KEY:-}" ]; then providers="${providers}minimax "; fi
  if [ -n "${DASHSCOPE_API_KEY:-}" ]; then providers="${providers}dashscope "; fi
  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then providers="${providers}anthropic "; fi
  if [ -n "${OPENAI_API_KEY:-}" ]; then providers="${providers}openai "; fi
  printf '%s' "${providers% }"
}

OMNICODER_PROVIDERS=$(detect_providers)
export OMNICODER_PROVIDERS

# ---- banner -----------------------------------------------------------------
print_banner() {
  # Respect NO_COLOR and non-TTY stdout so we do not pollute piped output.
  if [ -n "${NO_COLOR:-}" ] || [ ! -t 1 ]; then
    printf '%s\n' "OmniCoder v${OMNICODER_VERSION}"
    return
  fi
  cat <<'BANNER'
   ___                  _ _____          _
  / _ \ _ __ ___  _ __ (_)  ___|__  _ __| | ___ _ __
 | | | | '_ ` _ \| '_ \| | |_ / _ \| '__| |/ _ \ '__|
 | |_| | | | | | | | | | |  _| (_) | |  | |  __/ |
  \___/|_| |_| |_|_| |_|_|_|  \___/|_|  |_|\___|_|
BANNER
  printf '  OmniCoder v%s  (opencode-powered)\n\n' "$OMNICODER_VERSION"
}

maybe_show_banner() {
  # First-invocation banner; guarded by a flag file. Non-fatal if write fails.
  if [ -f "$OMNICODER_BANNER_FLAG" ]; then return; fi
  mkdir -p "$OMNICODER_HOME" 2>/dev/null || return 0
  print_banner
  : > "$OMNICODER_BANNER_FLAG" 2>/dev/null || true
}

# ---- doctor -----------------------------------------------------------------
doctor_run() {
  printf 'OmniCoder doctor — v%s\n\n' "$OMNICODER_VERSION"

  issues=0

  # 1. opencode binary
  if command -v opencode >/dev/null 2>&1; then
    oc_path=$(command -v opencode)
    printf '  [ok]   opencode binary       %s\n' "$oc_path"
  else
    printf '  [miss] opencode binary       not in PATH (run scripts/install.sh)\n'
    issues=$((issues + 1))
  fi

  # 2. engram binary (optional but recommended for shared memory)
  if command -v engram >/dev/null 2>&1; then
    eg_path=$(command -v engram)
    printf '  [ok]   engram binary         %s\n' "$eg_path"
  else
    printf '  [warn] engram binary         not in PATH (MCP memory disabled)\n'
  fi

  # 3. OMNICODER_HOME
  if [ -d "$OMNICODER_HOME" ]; then
    printf '  [ok]   OMNICODER_HOME        %s\n' "$OMNICODER_HOME"
  else
    printf '  [miss] OMNICODER_HOME        %s (not created)\n' "$OMNICODER_HOME"
    issues=$((issues + 1))
  fi

  # 4. user config
  if [ -f "$OMNICODER_USER_CONFIG" ]; then
    printf '  [ok]   user config           %s\n' "$OMNICODER_USER_CONFIG"
  else
    printf '  [info] user config           not present (using fork defaults)\n'
  fi

  # 5. providers
  printf '\nProviders:\n'
  if [ -n "${NVIDIA_API_KEY:-}" ]; then printf '  [ok]   NVIDIA_API_KEY        set\n'; else printf '  [--]   NVIDIA_API_KEY        unset\n'; fi
  if [ -n "${MINIMAX_API_KEY:-}" ]; then printf '  [ok]   MINIMAX_API_KEY       set\n'; else printf '  [--]   MINIMAX_API_KEY       unset\n'; fi
  if [ -n "${DASHSCOPE_API_KEY:-}" ]; then printf '  [ok]   DASHSCOPE_API_KEY     set\n'; else printf '  [--]   DASHSCOPE_API_KEY     unset\n'; fi
  if [ -n "${ANTHROPIC_API_KEY:-}" ]; then printf '  [ok]   ANTHROPIC_API_KEY     set\n'; else printf '  [--]   ANTHROPIC_API_KEY     unset\n'; fi
  if [ -n "${OPENAI_API_KEY:-}" ]; then printf '  [ok]   OPENAI_API_KEY        set\n'; else printf '  [--]   OPENAI_API_KEY        unset\n'; fi

  if [ -z "$OMNICODER_PROVIDERS" ]; then
    printf '\n  [warn] no provider API keys detected — set at least one before running.\n'
    issues=$((issues + 1))
  fi

  printf '\n'
  if [ "$issues" -eq 0 ]; then
    printf 'Status: healthy\n'
    return 0
  fi
  # Per feedback_ci_windows_bat.md #8 — doctor on a fresh runner returning 1
  # is expected, so we exit 1 only to let CI tolerate it explicitly.
  printf 'Status: %d issue(s) found\n' "$issues"
  return 1
}

# ---- arg parsing ------------------------------------------------------------
if [ "$#" -ge 1 ]; then
  case $1 in
    --omnicoder-version)
      core_version="(opencode not installed)"
      if command -v opencode >/dev/null 2>&1; then
        core_version=$(opencode --version 2>/dev/null || printf 'unknown')
      fi
      printf 'omnicoder %s\n' "$OMNICODER_VERSION"
      printf 'opencode  %s\n' "$core_version"
      exit 0
      ;;
    doctor)
      shift
      doctor_run
      exit $?
      ;;
    update|upgrade)
      # Reinstall from npm — works even when the wrapper was installed by
      # scripts/install.sh rather than `npm install -g`, because npm will
      # overwrite /usr/local/bin/omnicoder with its own wrapper.
      shift
      printf '[omnicoder] updating to latest @alpha from npm…\n'
      if ! command -v npm >/dev/null 2>&1; then
        printf 'omnicoder: npm not found. Install Node.js 18+ first.\n' >&2
        exit 127
      fi
      exec npm install -g @nicolas2601/omnicoder@alpha "$@"
      ;;
  esac
fi

# ---- dispatch to opencode ---------------------------------------------------
# Prefer the source build from the omnicoder repo when available — that's
# the one that carries the purple theme, the `omnicoder` splash, and the
# plugin fast-paths that upstream opencode doesn't ship with. Fall back to
# the globally installed `opencode` binary when the repo isn't checked out
# on this machine so a wrapper-only install still works.
OMNICODER_REPO="${OMNICODER_REPO:-$HOME/omnicoder-v5}"
OMNICODER_SRC_ENTRY="$OMNICODER_REPO/packages/opencode/src/index.ts"
# bun's monorepo install hoists per workspace, so @opentui lives under the
# opencode package, not the repo root.
OMNICODER_SRC_DEPS="$OMNICODER_REPO/packages/opencode/node_modules/@opentui/core"

can_run_source() {
  [ -f "$OMNICODER_SRC_ENTRY" ] && [ -d "$OMNICODER_SRC_DEPS" ] && command -v bun >/dev/null 2>&1
}

maybe_show_banner

# Point opencode at the user's OmniCoder config only if it exists. Otherwise we
# let opencode use its own default resolution (respecting XDG/project files).
if [ -f "$OMNICODER_USER_CONFIG" ]; then
  OPENCODE_CONFIG="$OMNICODER_USER_CONFIG"
  export OPENCODE_CONFIG
fi

# Preserve the user's working directory — opencode opens the project at its
# own process.cwd() and spawns bash from there, so if we `cd` into the repo
# the user sees the repo path (bug in alpha.8/9 where `pwd` inside the TUI
# returned ~/omnicoder-v5/packages/opencode regardless of launch dir).
SAVED_CWD=$(pwd)

if can_run_source; then
  # When the user invoked `omnicoder` with no args, pass the launch dir as
  # the [project] positional so opencode opens it.  With args we trust the
  # user's intent verbatim.
  if [ "$#" -eq 0 ]; then
    set -- "$SAVED_CWD"
  fi
  # `--conditions=browser` mirrors the root `dev` script so @opentui/solid's
  # browser entrypoint wins over the server-side one — same runtime shape as
  # `bun dev` from the repo root.
  exec bun run --cwd "$OMNICODER_REPO/packages/opencode" --conditions=browser src/index.ts "$@"
fi

if ! command -v opencode >/dev/null 2>&1; then
  printf 'omnicoder: opencode is not installed.\n' >&2
  printf '  Install via npm:  npm install -g @nicolas2601/omnicoder@alpha\n' >&2
  exit 127
fi

# Pass the user's cwd when no project arg was given.  opencode's positional
# [project] argument lets the user open any folder regardless of where the
# opencode binary lives.
if [ "$#" -eq 0 ]; then
  exec opencode "$SAVED_CWD"
fi
exec opencode "$@"
